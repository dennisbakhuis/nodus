# Root environment file consumed by docker-compose.
# Copy to `.env` and adjust. Every flag is OPTIONAL — leave a line out or set
# it empty to get the documented default. The backend-specific reference
# (with full descriptions of every NODUS_* var) lives at
# `src/backend/.env.example`.


# ─── Deployment mode ───────────────────────────────────────────────────────
#
# `dev` or `test` enables seeding the four demo accounts via
# `make seed-demo-users`. Anything else (including empty) blocks demo seeding.
NODUS_ENV=dev


# ─── Auth ──────────────────────────────────────────────────────────────────
#
# Turn the auth system OFF — every request becomes a synthetic admin
# (username "local", role Admin). Only safe for single-user local dev.
#NODUS_AUTH_DISABLED=1

# Disable the anonymous / public-reader surface. Every API endpoint will
# require a Reader/Writer/Admin login; anonymous callers and accounts with
# role `public_reader` get 401. No effect when NODUS_AUTH_DISABLED is set.
#NODUS_PUBLIC_READER_DISABLED=1


# ─── Database ──────────────────────────────────────────────────────────────
#
# Default is SQLite at `src/backend/radar.db`. Override for Postgres:
#NODUS_DATABASE_URL=postgresql+psycopg://user:pass@host:5432/nodus

# Explicit opt-in to a destructive rebuild when the existing DB lacks the v2
# schema. Equivalent: `uv run python -m app.cli db reset --confirm`.
#NODUS_RESET_DB=1


# ─── CORS ──────────────────────────────────────────────────────────────────
#
# Comma-separated allowed origins. Default: http://localhost:5173 (vite dev).
#NODUS_CORS_ORIGINS=http://localhost:5173,http://localhost:3000


# ─── OpenAPI docs (Swagger / ReDoc) ────────────────────────────────────────
#
#NODUS_DOCS_DISABLED=1
#NODUS_DOCS_USERNAME=admin
#NODUS_DOCS_PASSWORD=change-me


# ─── Reverse-proxy mount ───────────────────────────────────────────────────
#
# Set when the container is mounted behind a path prefix (e.g. behind a
# reverse proxy stripping "/radar").
#NODUS_ROOT_PATH=/radar


# ─── Entra ID (Azure AD) SSO ───────────────────────────────────────────────
#
# See `docs/auth.md` and `src/backend/.env.example` for the full walkthrough.
#NODUS_AUTH_ENTRA_ENABLED=1
#NODUS_AUTH_ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000
#NODUS_AUTH_ENTRA_CLIENT_ID=00000000-0000-0000-0000-000000000000
#NODUS_AUTH_ENTRA_CLIENT_SECRET=
#NODUS_AUTH_ENTRA_REDIRECT_URI=https://radar.example.com/auth/callback
#NODUS_AUTH_ENTRA_GROUP_ADMIN=
#NODUS_AUTH_ENTRA_GROUP_WRITER=
#NODUS_AUTH_ENTRA_GROUP_READER=
#NODUS_AUTH_ENTRA_GROUP_PUBLIC_READER=
