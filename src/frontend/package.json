{
  "name": "nodus-frontend",
  "description": "Nodus Technology Radar frontend (React + Vite + TypeScript)",
  "private": true,
  "version": "0.3.6",
  "type": "module",
  "license": "Apache-2.0",
  "author": "Dennis Bakhuis",
  "homepage": "https://github.com/dennisbakhuis/nodus",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dennisbakhuis/nodus.git"
  },
  "bugs": {
    "url": "https://github.com/dennisbakhuis/nodus/issues"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && npm run lint && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint src --ext .ts,.tsx --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write src",
    "gen:api": "openapi-ts"
  },
  "dependencies": {
    "d3": "^7.9.0",
    "jspdf": "^4.2.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-easy-crop": "^5.5.7",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.15.0",
    "remark-gfm": "^4.0.1",
    "svg2pdf.js": "^2.7.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@hey-api/openapi-ts": "^0.97.1",
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/d3": "^7.4.3",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitejs/plugin-react": "^6.0.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "jsdom": "^29.0.0",
    "prettier": "^3.5.3",
    "typescript": "^6.0.0",
    "vite": "^8.0.0",
    "vitest": "^4.0.0"
  }
}
