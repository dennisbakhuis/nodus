# Example environment for the Nodus Technology Radar backend.
# Copy to `.env` and adjust. Every flag is OPTIONAL — leave a line out or set
# it empty to get the documented default.
#
# Naming: every backend env var is prefixed with `NODUS_`.


# ─── Auth ──────────────────────────────────────────────────────────────────
#
# Disable the auth system entirely. Every request is treated as a synthetic
# admin (username "local", role Admin). Intended for local single-user
# development — DO NOT set in production. The frontend will display an
# "Auth disabled" badge while this is active so the mode is obvious.
#
# Accepted truthy values: 1, true, yes, on
#NODUS_AUTH_DISABLED=1

# Deployment environment. Only `dev` or `test` permits seeding demo users
# (demo_public / demo_reader / demo_writer / demo_admin, password "demo").
# Anything else (including empty) blocks demo seeding — safe for production.
#NODUS_ENV=dev

# Disable the public-reader fallback. By default, anonymous (logged-out)
# visitors see the radar as a `PublicReader`. When this flag is set, every
# API endpoint returns 401 to anonymous callers and to accounts whose role
# is `public_reader`, so the deployment requires a Reader/Writer/Admin
# login to see anything at all.
#
# Has no effect when NODUS_AUTH_DISABLED=1 is also set — that flag wins.
#
# Accepted truthy values: 1, true, yes, on
#NODUS_PUBLIC_READER_DISABLED=1


# ─── CORS ──────────────────────────────────────────────────────────────────
#
# Comma-separated list of allowed origins. Default: http://localhost:5173
# (vite dev server). Example for prod:
#NODUS_CORS_ORIGINS=https://radar.example.com,https://radar-staging.example.com


# ─── OpenAPI docs (Swagger / ReDoc) ────────────────────────────────────────
#
# Hide /docs, /redoc, /openapi.json entirely (all return 404).
#NODUS_DOCS_DISABLED=1

# Or protect them with HTTP Basic auth.
#NODUS_DOCS_USERNAME=admin
#NODUS_DOCS_PASSWORD=change-me

# Self-host Swagger/ReDoc assets when the runtime cannot reach jsdelivr
# (strict egress, CSP, etc.). Leave empty to use the public CDN.
#NODUS_SWAGGER_JS_URL=
#NODUS_SWAGGER_CSS_URL=
#NODUS_REDOC_JS_URL=


# ─── Reverse-proxy mount ───────────────────────────────────────────────────
#
# Set when the container is mounted behind a path prefix (e.g. behind a
# reverse proxy stripping "/radar"). FastAPI uses this to rewrite "Try it
# out" URLs and the openapi.json reference.
#NODUS_ROOT_PATH=/radar


# ─── Database ──────────────────────────────────────────────────────────────
#
# Explicit opt-in to a destructive rebuild when the existing DB lacks the v2
# schema. Without this flag the app refuses to start instead of silently
# deleting data. Equivalent: `uv run python -m app.cli db reset --confirm`.
#NODUS_RESET_DB=1


# ─── Entra ID (Azure AD) — OIDC SSO ─────────────────────────────────────────
#
# Configure these keys to enable Entra ID SSO. Full setup walkthrough in
# docs/auth.md. Leave commented out to use local auth or auth_disabled mode.
#
#NODUS_AUTH_ENTRA_ENABLED=1
#NODUS_AUTH_ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000
#NODUS_AUTH_ENTRA_CLIENT_ID=00000000-0000-0000-0000-000000000000
#NODUS_AUTH_ENTRA_CLIENT_SECRET=...
#NODUS_AUTH_ENTRA_REDIRECT_URI=https://radar.example.com/auth/callback
#
# Entra group object IDs → application role. On every Entra login, the
# user's group membership is checked and the highest-privilege match wins.
# No match → PublicReader.
#NODUS_AUTH_ENTRA_GROUP_ADMIN=
#NODUS_AUTH_ENTRA_GROUP_WRITER=
#NODUS_AUTH_ENTRA_GROUP_READER=
#NODUS_AUTH_ENTRA_GROUP_PUBLIC_READER=
